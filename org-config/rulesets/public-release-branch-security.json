{
  "name": "public-release-branch-security",
  "target": "branch",
  "enforcement": "active",
  "bypass_actors": [],
  "conditions": {
    "ref_name": {
      "exclude": [],
      "include": [
        "~DEFAULT_BRANCH",
        "refs/heads/releases/*"
      ]
    },
    "repository_property": {
      "exclude": [],
      "include": [
        {
          "name": "visibility",
          "source": "system",
          "property_values": [
            "public"
          ]
        }
      ]
    }
  },
  "rules": [
    {
      "type": "deletion"
    },
    {
      "type": "required_linear_history"
    },
    {
      "type": "required_signatures"
    },
    {
      "type": "non_fast_forward"
    }
  ]
}
