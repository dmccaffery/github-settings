{
  "name": "public-fork-only",
  "target": "branch",
  "enforcement": "active",
  "bypass_actors": [],
  "conditions": {
    "repository_property": {
      "exclude": [],
      "include": [
        {
          "name": "visibility",
          "source": "system",
          "property_values": ["public"]
        }
      ]
    },
    "ref_name": {
      "exclude": [
        "refs/heads/release-please--*",
        "refs/heads/dependabot/**",
        "refs/heads/main"
      ],
      "include": ["~ALL"]
    }
  },
  "rules": [
    {
      "type": "update"
    },
    {
      "type": "creation"
    }
  ]
}
