{
  "name": "public-pull-request-required",
  "target": "branch",
  "enforcement": "active",
  "bypass_actors": [
    {
      "actor_id": null,
      "actor_type": "OrganizationAdmin",
      "bypass_mode": "always"
    },
    {
      "actor_id": 4048320,
      "actor_type": "Integration",
      "bypass_mode": "always"
    }
  ],
  "conditions": {
    "repository_property": {
      "exclude": [
        {
          "name": "bypass-policies",
          "source": "custom",
          "property_values": [
            "true"
          ]
        }
      ],
      "include": [
        {
          "name": "visibility",
          "source": "system",
          "property_values": [
            "public"
          ]
        }
      ]
    },
    "ref_name": {
      "exclude": [],
      "include": [
        "~DEFAULT_BRANCH",
        "refs/heads/releases/*"
      ]
    }
  },
  "rules": [
    {
      "type": "pull_request",
      "parameters": {
        "required_approving_review_count": 1,
        "dismiss_stale_reviews_on_push": true,
        "required_reviewers": [],
        "require_code_owner_review": true,
        "require_last_push_approval": true,
        "required_review_thread_resolution": true,
        "allowed_merge_methods": [
          "merge"
        ]
      }
    }
  ]
}
