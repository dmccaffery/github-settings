{
  "name": "public-version-tags-only",
  "target": "tag",
  "enforcement": "active",
  "bypass_actors": [],
  "conditions": {
    "repository_property": {
      "exclude": [],
      "include": [
        {
          "name": "visibility",
          "source": "system",
          "property_values": [
            "public"
          ]
        }
      ]
    },
    "ref_name": {
      "exclude": [
        "refs/tags/v*"
      ],
      "include": [
        "~ALL"
      ]
    }
  },
  "rules": [
    {
      "type": "creation"
    }
  ]
}
